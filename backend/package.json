{
  "name": "claude-code-web-backend",
  "version": "0.1.0",
  "description": "Fastify backend for web-based terminal emulator with PTY support.",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "build": "tsup src/index.ts --format esm --sourcemap --dts --external ws",
    "dev": "tsx watch src/index.ts",
    "start": "node --enable-source-maps dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.1.72",
    "@fastify/compress": "^8.3.1",
    "@fastify/cors": "^11.1.0",
    "@fastify/multipart": "^9.3.0",
    "@fastify/static": "^9.0.0",
    "@fastify/websocket": "^11.2.0",
    "@homebridge/node-pty-prebuilt-multiarch": "^0.13.1",
    "@simplewebauthn/server": "^13.2.3",
    "@types/cross-spawn": "^6.0.6",
    "archiver": "^7.0.1",
    "bcrypt": "^6.0.0",
    "better-sqlite3": "^12.5.0",
    "cross-spawn": "^7.0.6",
    "dotenv": "^17.2.3",
    "execa": "^9.6.1",
    "fastify": "^5.6.1",
    "jsonwebtoken": "^9.0.3",
    "pino": "^10.1.0",
    "pixelmatch": "^7.1.0",
    "playwright": "^1.58.0",
    "pngjs": "^7.0.0",
    "terminal-v4": "file:..",
    "unzipper": "^0.12.3",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/archiver": "^7.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.9.1",
    "@types/supertest": "^6.0.3",
    "@types/unzipper": "^0.10.11",
    "supertest": "^7.1.4",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.17"
  },
  "engines": {
    "node": ">=18"
  }
}
